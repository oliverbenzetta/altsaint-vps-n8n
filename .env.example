# Container Name: N8N
# File Name: .env.example
# Description: Example environment variables for the N8N service stack (N8N, PostgreSQL, Qdrant).
# Docker Internal Network: altsaint-net
# Version: 1.1.0
# Author: Alt Saint Group LTD

# Example environment variables for the n8n, Postgres and Qdrant stack

# Project Name
COMPOSE_PROJECT_NAME=n8n-production

# Timezone settings
TZ=Europe/London
GENERIC_TIMEZONE=Europe/London

# HTTPS Domain Configuration 
# Host and proxy configuration Domain config
# N8N_HOST=subdomain.domain.com
# N8N_PORT=5678
# N8N_IP_HOST_PORT=5678
# N8N_PROTOCOL=https
# N8N_EDITOR_BASE_URL=https://subdomain.domain.com
# N8N_API_BASE_URL=https://subdomain.domain.com
# WEBHOOK_URL=https://subdomain.domain.com/
# N8N_PROXY_HOPS=1
# N8N_TRUSTED_PROXIES=*
# N8N_SECURE_COOKIE=true

# HTTP Domain Configuration
# Host and proxy configuration Domain config Jask Local Http
# Replace with your local domain if required
N8N_HOST=ms-altsaint.local
N8N_PORT=5678
N8N_IP_HOST_PORT=5679
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://ms-altsaint.local:5679
N8N_API_BASE_URL=http://ms-altsaint.local:5679
WEBHOOK_URL=http://ms-altsaint.local:5679/
N8N_PROXY_HOPS=1
N8N_TRUSTED_PROXIES=*
N8N_SECURE_COOKIE=false

# HTTP Local IP Configuration
# Host and proxy configuration Local IP config
# N8N_HOST=127.0.0.1
# N8N_PORT=5678
# N8N_PROTOCOL=http
# N8N_EDITOR_BASE_URL=http://127.0.0.1:5678
# N8N_API_BASE_URL=http://127.0.0.1:5678
# WEBHOOK_URL=http://127.0.0.1:5678/
# N8N_PROXY_HOPS=1
# N8N_TRUSTED_PROXIES=*
# N8N_SECURE_COOKIE=false   

# Localhost Configuration
# Host and proxy configuration Localhost config
# N8N_HOST=localhost
# N8N_PORT=5678
# N8N_PROTOCOL=http
# N8N_EDITOR_BASE_URL=http://localhost:5678
# N8N_API_BASE_URL=http://localhost:5678
# WEBHOOK_URL=http://localhost:5678/
# N8N_PROXY_HOPS=1
# N8N_TRUSTED_PROXIES=*
# N8N_SECURE_COOKIE=false

# Security and compatibility settings
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
N8N_GIT_NODE_DISABLE_BARE_REPOS=true
N8N_RUNNERS_ENABLED=true
# N8N_LOG_LEVEL=debug

# Database settings for n8n (Standardized variables)
DB_TYPE=postgresdb
DB_PORT=5432
DB_EXTERNAL_PORT=5434
DB_NAME=n8n
DB_USER=change_me_user
DB_PASSWORD=change_me_password

# Qdrant settings
QDRANT_HOST_PORT=6334
# QDRANT_API_KEY=your-strong-api-key

# Redis settings (Internal)
REDIS_PORT=6379

# MCP Server settings
MCP_N8N_API_KEY=your-n8n-api-key
MCP_PORT=3001
MCP_AUTH_TOKEN=your-mcp-auth-token

# Fix for permission issues on volume mounts
UID=1000
GID=1000